{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "workspaceui",
  "homepage": "https://github.com/jayclydeTags/workspaceui",
  "items": [
    {
      "name": "workspace-context",
      "type": "registry:ui",
      "title": "Workspace Context",
      "description": "Shared drag context for WorkspaceTabs and Workspace. Installed automatically as a dependency — you do not need to add this directly.",
      "dependencies": [],
      "registryDependencies": [],
      "files": [
        {
          "path": "src/registry/bases/base/workspaceui/workspace-context.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "workspace-tabs",
      "type": "registry:ui",
      "title": "Workspace Tabs",
      "description": "Chrome-style scrollable tab strip with closeable tabs, unread badges, overflow fade, and macOS-style curved active-tab connectors.",
      "dependencies": ["@base-ui/react", "lucide-react"],
      "registryDependencies": ["utils", "jayclydeTags/workspaceui/workspace-context"],
      "files": [
        {
          "path": "src/registry/bases/base/workspaceui/workspace-tabs.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "workspace-panel",
      "type": "registry:ui",
      "title": "Workspace Panel",
      "description": "Layout component used inside Workspace's renderTabContent to split a pane's content area vertically. One child fills the pane; two children stack with a drag-to-resize handle. Drag-to-reorder works via the parent Workspace context.",
      "dependencies": ["@base-ui/react", "lucide-react", "react-resizable-panels"],
      "registryDependencies": ["jayclydeTags/workspaceui/workspace-tabs", "resizable", "utils"],
      "files": [
        {
          "path": "src/registry/bases/base/workspaceui/workspace-panel.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "workspace",
      "type": "registry:ui",
      "title": "Workspace",
      "description": "Self-contained workspace with tab-based panels: closing a panel's last tab collapses the panel; closing all panels reveals a configurable fallback. Exposes useWorkspace context and a WorkspaceHandle ref for programmatic control.",
      "dependencies": ["@base-ui/react", "react-resizable-panels", "lucide-react"],
      "registryDependencies": ["resizable", "jayclydeTags/workspaceui/workspace-tabs", "jayclydeTags/workspaceui/workspace-context", "utils"],
      "files": [
        {
          "path": "src/registry/bases/base/workspaceui/workspace.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "page",
      "type": "registry:ui",
      "title": "Page",
      "description": "Page shell with an optional header (title/subtitle, breadcrumbs, visual, badge, actions) and a content area that can be padded.",
      "dependencies": [],
      "registryDependencies": ["breadcrumb", "utils"],
      "files": [
        {
          "path": "src/registry/bases/base/workspaceui/page.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "dashboard-01",
      "type": "registry:block",
      "title": "Dashboard 01",
      "description": "Collapsible sidebar nav paired with the Workspace component. Sidebar items open tabs; repeat clicks focus the existing tab.",
      "dependencies": ["@base-ui/react", "lucide-react", "react-resizable-panels"],
      "registryDependencies": ["jayclydeTags/workspaceui/workspace", "sidebar", "utils"],
      "files": [
        {
          "path": "src/registry/bases/base/blocks/dashboard-01/page.tsx",
          "type": "registry:page",
          "target": "app/dashboard/page.tsx"
        },
        {
          "path": "src/registry/bases/base/blocks/dashboard-01/components/app-sidebar.tsx",
          "type": "registry:block"
        },
        {
          "path": "src/registry/bases/base/blocks/dashboard-01/components/dashboard-content.tsx",
          "type": "registry:block"
        }
      ]
    },
    {
      "name": "activity-log-01",
      "type": "registry:block",
      "title": "Activity Log 01",
      "description": "Filterable activity log with a responsive datatable — collapses to cards on narrow panes.",
      "dependencies": ["lucide-react"],
      "registryDependencies": [
        "avatar",
        "badge",
        "button",
        "empty",
        "input-group",
        "dropdown-menu",
        "pagination",
        "select",
        "table",
        "jayclydeTags/workspaceui/page"
      ],
      "files": [
        {
          "path": "src/registry/bases/base/blocks/activity-log-01/page.tsx",
          "type": "registry:page",
          "target": "app/activity-log/page.tsx"
        },
        {
          "path": "src/registry/bases/base/blocks/activity-log-01/data.ts",
          "type": "registry:block"
        },
        {
          "path": "src/registry/bases/base/blocks/activity-log-01/components/data-table.tsx",
          "type": "registry:block"
        }
      ]
    },
    {
      "name": "activity-feed-01",
      "type": "registry:block",
      "title": "Activity Feed 01",
      "description": "Grouped activity timeline with type/user filters and running stats.",
      "dependencies": ["lucide-react"],
      "registryDependencies": [
        "avatar",
        "button",
        "dropdown-menu",
        "jayclydeTags/workspaceui/page"
      ],
      "files": [
        {
          "path": "src/registry/bases/base/blocks/activity-feed-01/page.tsx",
          "type": "registry:page",
          "target": "app/activity-feed/page.tsx"
        },
        {
          "path": "src/registry/bases/base/blocks/activity-feed-01/data.ts",
          "type": "registry:block"
        }
      ]
    }
  ]
}
