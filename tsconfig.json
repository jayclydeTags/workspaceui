{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    // vite/client kept for import.meta.glob typing in src/lib/{source,search}.ts;
    // drop it in Phase 1 once those are replaced by the fumadocs loader.
    "types": ["vite/client", "node"],
    "jsx": "preserve",
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    /* Strictness — carried over from the previous tsconfig.app.json */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      ".source": ["./.source"],
      ".source/*": ["./.source/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".source",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "out", ".next"]
}
